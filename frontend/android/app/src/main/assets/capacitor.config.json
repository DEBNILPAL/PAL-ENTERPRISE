{
	"appId": "com.palenterprise.ledger",
	"appName": "PAL Enterprise",
	"webDir": "dist",
	"server": {
		"cleartext": true
	},
	"android": {
		"allowMixedContent": true,
		"backgroundColor": "#020617"
	},
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 2000,
			"launchAutoHide": true,
			"backgroundColor": "#020617",
			"androidScaleType": "CENTER_CROP",
			"showSpinner": true,
			"spinnerColor": "#4f46e5"
		},
		"StatusBar": {
			"style": "DARK",
			"backgroundColor": "#020617"
		}
	}
}
